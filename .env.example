# UniMove — copy to .env at repo root (DO NOT commit .env)

# Supabase (Postgres + Storage; auth = Node JWT, not Supabase Auth)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# Node.js API
PORT=3000
NODE_ENV=development
JWT_SECRET=change-me-to-a-long-random-string-in-production
JWT_EXPIRES_IN=7d

# Cloudinary (customer avatar upload — API-010)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_PRESET=

# PayOS (payments)
PAYOS_CLIENT_ID=
PAYOS_API_KEY=
PAYOS_CHECKSUM_KEY=

# Goong Maps — địa chỉ VN (đăng ký: https://account.goong.io)
GOONG_API_KEY=
# GOONG_API_URL=https://rsapi.goong.io

# Google Maps (fallback, optional)
GOOGLE_MAPS_API_KEY=

# SMTP (forgot password OTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
PASSWORD_RESET_OTP_EXPIRES_MINUTES=10