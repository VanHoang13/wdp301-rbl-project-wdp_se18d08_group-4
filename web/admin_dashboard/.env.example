# ============================================================
# Admin Dashboard — Biến môi trường (MẪU)
# Copy: cp .env.example .env.local  (hoặc copy thủ công trên Windows)
# KHÔNG commit file .env.local lên GitHub.
# ============================================================

# Supabase (public keys — OK để dùng ở client)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Service role — chỉ dùng phía server (Server Actions), không expose ra browser
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Backend API
NEXT_PUBLIC_API_URL=http://localhost:5000/api
