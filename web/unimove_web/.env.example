# Biến môi trường cho Vercel (web/unimove_web)
# Copy từng dòng vào Vercel → Project → Settings → Environment Variables

# Bắt buộc — URL API backend
# Local: backend chạy port 3000, web chạy port 3001 (npm run dev trong web/unimove_web)
NEXT_PUBLIC_API_URL=http://localhost:3000/api
# Production: deploy BE riêng trên Render/Railway trước
# NEXT_PUBLIC_API_URL=https://YOUR-API.onrender.com/api

# Admin dashboard (Supabase)
NEXT_PUBLIC_SUPABASE_URL=https://byqwsmdgyojzgyhbladx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Chỉ server-side (admin) — đánh dấu Sensitive trên Vercel
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Tùy chọn — Google Sign-In
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
